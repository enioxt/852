    "governance:check": "bash -lc 'if [ -x \"$HOME/.egos/bin/egos-gov\" ]; then export PATH=\"$HOME/.egos/bin:$PATH\" && egos-gov check; else echo \"egos-gov not found\"; fi'",
    "governance:sync": "bash -lc 'if [ -x \"$HOME/.egos/bin/egos-gov\" ]; then export PATH=\"$HOME/.egos/bin:$PATH\" && egos-gov sync; else echo \"egos-gov not found\"; fi'",
