#!/bin/sh

echo "🔍 852 Inteligência — Pre-commit checks..."

# Type check
echo "→ TypeScript..."
npx tsc --noEmit 2>/dev/null
if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors found. Fix before committing."
  exit 1
fi

# Lint
echo "→ ESLint..."
npx eslint --max-warnings 0 src/ 2>/dev/null
if [ $? -ne 0 ]; then
  echo "⚠️  Lint warnings/errors. Proceeding anyway (soft gate)."
fi

# Check .env not committed
if git diff --cached --name-only | grep -q "^\.env$"; then
  echo "❌ BLOCKED: .env file must NOT be committed!"
  exit 1
fi

echo "✅ Pre-commit passed."

# EGOS Governance Check
[ -x "$HOME/.egos/bin/egos-gov" ] && "$HOME/.egos/bin/egos-gov" check --quiet || { echo "⚠️  Governance drift detected. Run: egos-gov sync"; }
