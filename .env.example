# DashScope (Alibaba) API Key for primary model
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OpenRouter API Key for paid Gemini 2.0 fallback
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional tertiary fallback for development only
OPENAI_API_KEY=your_openai_api_key_here

# Resend email provider env vars for email verification flow
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=Tira-Voz <no-reply@your-domain.com>

# Default Universal Mailer (Replaces Resend for Free emails such as Gmail/Brevo)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
SMTP_FROM="Tira-Voz <no-reply@egos.ia.br>"

NEXT_PUBLIC_CLARITY_ID=your_clarity_project_id_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
ADMIN_SETUP_KEY=your_admin_setup_key_here
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
PUBLIC_BASE_URL=https://852.egos.ia.br
ISSUE_ALERT_WEBHOOK_URL=https://your-webhook-endpoint.example.com
ISSUE_ALERT_WEBHOOK_SECRET=your_webhook_secret_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
