# ─────────────────────────────────────────────────────────────────────────────
# 852 Tira-Voz — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# BOOTSTRAP (obrigatórios — sempre no .env, NUNCA gerenciados pelo Integration Hub):
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, CONFIG_ENCRYPTION_KEY
#
# TUDO O MAIS pode ser configurado via /admin/integrations (Integration Hub)
# e fica armazenado criptografado no Supabase — portável entre ambientes/IDEs.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── BOOTSTRAP (mínimo obrigatório) ───────────────────────────────────────────

# Supabase — projeto lhscgsqhiooyatkebose
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Chave de criptografia para o Integration Hub (AES-256-GCM)
# Gerar: openssl rand -hex 32
CONFIG_ENCRYPTION_KEY=your_32_byte_hex_key_here

# Admin setup (para criar primeiro admin)
ADMIN_SETUP_KEY=your_admin_setup_key_here

# ── OPCIONAIS NO .env (Integration Hub gerencia os demais) ───────────────────
# Preencha aqui apenas se não usar o Integration Hub

# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=voce@gmail.com
# SMTP_PASS=sua-senha-de-app
# SMTP_FROM="Tira-Voz" <no-reply@egos.ia.br>

# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ISSUE_ALERT_WEBHOOK_URL=https://your-webhook-endpoint.example.com
# ISSUE_ALERT_WEBHOOK_SECRET=your_webhook_secret_here

# GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# PUBLIC_BASE_URL=https://852.egos.ia.br

# NEXT_PUBLIC_CLARITY_ID=your_clarity_project_id_here

# ─────────────────────────────────────────────────────────────────────────────
